<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- VS-like selection blue -->
    <SolidColorBrush x:Key="VSSelectionBrush" Color="#FF007ACC" />
    <SolidColorBrush x:Key="VSSelectionHoverBrush" Color="#FF1E90FF" />
    <SolidColorBrush x:Key="TreeItemForeground" Color="#FF222222" />
    <SolidColorBrush x:Key="TreeItemMuted" Color="#FF6B6B6B" />
    <Thickness x:Key="TreeItemPadding">6,4,6,4</Thickness>

    <!-- Compact TreeViewItem style closer to VS -->
    <Style TargetType="TreeViewItem">
        <Setter Property="Padding" Value="{StaticResource TreeItemPadding}"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TreeItemForeground}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- selection rectangle -->
                        <Border x:Name="SelectionBorder"
     Grid.Column="1"
     Background="Transparent"
     CornerRadius="2"
     Margin="0"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="4,2">
                            <!-- icon placeholder (set in DataTemplate) -->
                            <ContentPresenter x:Name="PART_Header" ContentSource="Header" RecognizesAccessKey="True"/>
                        </StackPanel>

                        <ItemsPresenter x:Name="ItemsHost" Grid.Column="1" Margin="18,0,0,0"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="SelectionBorder" Property="Background" Value="{StaticResource VSSelectionBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SelectionBorder" Property="Background" Value="{StaticResource VSSelectionHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Template" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- compact tree item header template (used in SolutionExplorer) -->
    <DataTemplate x:Key="SolutionTreeItemTemplate">
        <DockPanel LastChildFill="True" Margin="0">
            <material:PackIcon Kind="{Binding NodeType, Converter={StaticResource NodeTypeToVisibility}}" 
                         Width="16" Height="16" Margin="4,0" VerticalAlignment="Center" Foreground="{DynamicResource TreeItemForeground}"/>
            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Margin="6,0,0,0"/>
            <TextBlock Text="{Binding NodeType}" Foreground="{DynamicResource TreeItemMuted}" FontSize="11" HorizontalAlignment="Right" Margin="6,0,0,6"/>
        </DockPanel>
    </DataTemplate>

    <!-- small input style for search -->
    <Style TargetType="TextBox" x:Key="SearchTextBox">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Background" Value="#FFF7F7F7"/>
    </Style>

    <!-- converters must be available in App.xaml via merged dictionaries -->
</ResourceDictionary>