<UserControl x:Class="TangerineAutomationSystem.Views.ProjectExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TangerineAutomationSystem.Views"
             xmlns:models="clr-namespace:TangerineAutomationSystem.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="300">


    <UserControl.Resources>
        <!-- 项目树样式 -->
        <Style x:Key="ProjectTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 实验室模板 -->
        <HierarchicalDataTemplate DataType="{x:Type models:Laboratory}" 
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔬" FontSize="14" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Name}"/>
                <TextBlock Text="{Binding ProductionLines.Count, StringFormat=' ({0})'}" 
                           Foreground="#969696" 
                           Margin="2,0,0,0"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- 产线模板 -->
        <HierarchicalDataTemplate DataType="{x:Type models:ProductionLine}" 
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🏭" FontSize="14" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Name}"/>
                <TextBlock Text="{Binding Platforms.Count, StringFormat=' ({0})'}" 
                           Foreground="#969696" 
                           Margin="2,0,0,0"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- 平台模板 -->
        <HierarchicalDataTemplate DataType="{x:Type models:Platform}" 
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🖥️" FontSize="14" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Name}"/>
                <TextBlock Text="{Binding Modules.Count, StringFormat=' ({0})'}" 
                           Foreground="#969696" 
                           Margin="2,0,0,0"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- 模块模板 -->
        <!--<DataTemplate DataType="{x:Type models:UniversalModule}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙️" FontSize="14" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Name}"/>
            </StackPanel>
        </DataTemplate>-->
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource MenuBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="项目资源管理器" 
                       Foreground="{StaticResource ForegroundBrush}" 
                       FontWeight="SemiBold"
                       Margin="8,4"/>
        </Border>

        <!-- 项目树 -->
        <TreeView Grid.Row="1" 
                  ItemsSource="{Binding Project.Laboratories}"
                  ItemContainerStyle="{StaticResource ProjectTreeViewItemStyle}"
                  SelectedItemChanged="TreeView_SelectedItemChanged">

            <TreeView.ContextMenu>
                <ContextMenu Background="{StaticResource MenuBackgroundBrush}" Foreground="{StaticResource ForegroundBrush}">
                    <MenuItem Header="添加实验室" Command="{Binding DataContext.AddLaboratoryCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2, Mode=FindAncestor}}"/>
                    <MenuItem Header="添加产线" Command="{Binding DataContext.AddProductionLineCommand, RelativeSource={RelativeSource AncestorType=UserControl,AncestorLevel=2, Mode=FindAncestor}}"/>
                    <MenuItem Header="添加平台" Command="{Binding DataContext.AddPlatformCommand, RelativeSource={RelativeSource AncestorType=UserControl,AncestorLevel=2, Mode=FindAncestor}}"/>
                    <MenuItem Header="添加模块" Command="{Binding DataContext.AddModuleCommand, RelativeSource={RelativeSource AncestorType=UserControl,AncestorLevel=2, Mode=FindAncestor}}"/>
                    <Separator/>
                    <MenuItem Header="删除" Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl,AncestorLevel=2, Mode=FindAncestor}}"/>
                    <Separator/>
                    <MenuItem Header="重命名"/>
                    <MenuItem Header="属性"/>
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </Grid>
</UserControl>