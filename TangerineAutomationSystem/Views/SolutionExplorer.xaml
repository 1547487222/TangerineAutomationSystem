<UserControl x:Class="TangerineAutomationSystem.Views.SolutionExplorer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TangerineAutomationSystem.ViewModels"
             xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:TangerineAutomationSystem.Converters"
             Height="Auto" Width="Auto">
    <UserControl.Resources>
        <conv:NodeTypeToPackIconKindConverter x:Key="NodeTypeToPackIconKindConverter"/>

        <!-- header template: icon + name + muted node type -->
        <DataTemplate x:Key="SolutionTreeItemHeader" DataType="{x:Type vm:TreeNodeViewModel}">
            <DockPanel LastChildFill="True" Margin="0">
                <material:PackIcon Kind="{Binding NodeType, Converter={StaticResource NodeTypeToPackIconKindConverter}}"
                           Width="16" Height="16" Margin="6,0" VerticalAlignment="Center" Foreground="{DynamicResource TreeItemForeground}"/>
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                <TextBlock Text="{Binding NodeType}" Foreground="{DynamicResource TreeItemMuted}" FontSize="11" HorizontalAlignment="Right" Margin="6,0,6,0"/>
            </DockPanel>
        </DataTemplate>

        <!-- recursive hierarchical template: uses the header template for each node's header,
         and binds ItemsSource to Children so it recurses for all levels -->
        <HierarchicalDataTemplate x:Key="SolutionHierarchicalTemplate"
                              ItemsSource="{Binding Children}">
            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource SolutionTreeItemHeader}"/>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="6">
            <TextBox x:Name="SearchBox" Style="{StaticResource SearchTextBox}" Width="260" VerticalAlignment="Center"
                TextChanged="SearchBox_TextChanged"/>
        </DockPanel>

        <!-- Use the hierarchical template as the TreeView.ItemTemplate so every level can expand -->
        <TreeView x:Name="ExplorerTree" Grid.Row="1" ItemsSource="{Binding Projects}"
              ItemTemplate="{StaticResource SolutionHierarchicalTemplate}"
              Margin="4"
              SelectedItemChanged="ExplorerTree_SelectedItemChanged">
            <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
                </Style>
            </TreeView.Resources>

            <!-- IMPORTANT: bind Command and CommandParameter via PlacementTarget to access the host DataContext -->
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="添加产线"
                    Command="{Binding PlacementTarget.DataContext.AddLineCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    Visibility="{Binding PlacementTarget.SelectedItem.NodeType, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource NodeTypeToVisibility}, ConverterParameter=Lab}"/>

                    <MenuItem Header="添加平台"
                    Command="{Binding PlacementTarget.DataContext.AddPlatformCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    Visibility="{Binding PlacementTarget.SelectedItem.NodeType, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource NodeTypeToVisibility}, ConverterParameter=Line}"/>

                    <Separator/>

                    <MenuItem Header="添加模块"
                    Command="{Binding PlacementTarget.DataContext.AddModuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    Visibility="{Binding PlacementTarget.SelectedItem.NodeType, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource NodeTypeToVisibility}, ConverterParameter=Platform}"/>

                    <MenuItem Header="添加托盘资源"
                    Command="{Binding PlacementTarget.DataContext.AddTrayResourceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    Visibility="{Binding PlacementTarget.SelectedItem.NodeType, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource NodeTypeToVisibility}, ConverterParameter=Platform}"/>

                    <Separator/>

                    <MenuItem Header="重命名"
                    Command="{Binding PlacementTarget.DataContext.RenameNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>

                    <MenuItem Header="删除"
                    Command="{Binding PlacementTarget.DataContext.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </Grid>
</UserControl>