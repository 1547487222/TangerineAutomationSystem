<UserControl x:Class="TangerineAutomationSystem.Views.ProcessEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TangerineAutomationSystem.ViewModels"
             xmlns:controls="clr-namespace:TangerineAutomationSystem.Views.Controls">
    <UserControl.DataContext>
        <vm:ProcessEditorViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <controls:NodifyHostControl x:Name="NodeHost" />

        <controls:PropertyEditorHost Grid.Column="1" SelectedObject="{Binding SelectedNode.Config, Mode=TwoWay}" />
    </Grid>
</UserControl>