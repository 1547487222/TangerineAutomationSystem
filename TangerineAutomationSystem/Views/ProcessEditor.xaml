<UserControl x:Class="TangerineAutomationSystem.Views.ProcessEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TangerineAutomationSystem.ViewModels">
    <UserControl.DataContext>
        <vm:ProcessEditorViewModel />
    </UserControl.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#FFF7F7F7" Padding="8">
            <TextBlock Text="Toolbox" FontWeight="Bold" Margin="0,0,0,8" />
            <Button Content="添加平台任务到当前流" Command="{Binding AddPlatformTaskCommand}" Margin="0,4" />
            <Button Content="保存当前工艺" Command="{Binding SaveFlowCommand}" Margin="0,4" />
        </StackPanel>

        <Border Grid.Column="1" Background="White" BorderBrush="#FFE6EEF8" BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Canvas Background="#FFF8FAFC" Width="1400" Height="900">
                    <ItemsControl ItemsSource="{Binding Nodes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="#FFCCDDEE" BorderThickness="1" Padding="6" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Kind}" Foreground="Gray" FontSize="11" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="2" Background="#FFF7F7F7" BorderBrush="#FFE6EEF8" BorderThickness="1" Padding="8">
            <StackPanel>
                <TextBlock Text="Node Properties" FontWeight="Bold" Margin="0,0,0,8" />
                <StackPanel DataContext="{Binding SelectedNode}">
                    <TextBlock Text="名称" />
                    <TextBox Text="{Binding Name, Mode=TwoWay}" />
                    <TextBlock Text="类型" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding Kind}" Foreground="Gray" />
                    <TextBlock Text="Config JSON" Margin="0,8,0,0" />
                    <TextBox Text="{Binding ConfigJson, Mode=TwoWay}" AcceptsReturn="True" Height="220" />
                    <Button Content="Execute PlatformTask" Margin="0,8,0,0" Click="ExecutePlatformTask_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>