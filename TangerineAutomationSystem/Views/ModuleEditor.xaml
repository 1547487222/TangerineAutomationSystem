<UserControl x:Class="TangerineAutomationSystem.Views.ModuleEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:TangerineAutomationSystem.Services"
             xmlns:models="clr-namespace:TangerineAutomationSystem.Models"
             Height="220">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>
    <Border BorderBrush="LightGray" BorderThickness="1" Padding="8">
        <StackPanel>
            <TextBlock Text="模块编辑器（由 ModuleProvider 提供）" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Margin="0,8">
                <TextBlock Text="提供器:" VerticalAlignment="Center" />
                <ComboBox x:Name="ProviderCombo" Width="220" Margin="8,0" DisplayMemberPath="Name"/>
                <Button Content="应用提供器" Click="ApplyProvider_Click" />
            </StackPanel>
            <ContentControl x:Name="ProviderEditorArea" />
        </StackPanel>
    </Border>
</UserControl>