<UserControl x:Class="TangerineAutomationSystem.Views.ModuleProviderEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TangerineAutomationSystem.ViewModels"
             Height="460">
    <UserControl.DataContext>
        <vm:ModuleProviderEditorViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Providers list -->
        <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Padding="8" Margin="4">
            <StackPanel>
                <TextBlock Text="模块提供器" FontWeight="Bold" FontSize="14"/>
                <ListBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}" DisplayMemberPath="DisplayName" Height="200" Margin="0,8"/>
                <Button Content="刷新提供器" Command="{Binding RefreshProvidersCommand}" Margin="0,8"/>
                <TextBlock Text="可用实例" FontWeight="Bold" Margin="0,12"/>
                <ListBox ItemsSource="{Binding Instances}" DisplayMemberPath="InstanceName" Height="160" />
            </StackPanel>
        </Border>

        <!-- Editor area -->
        <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Padding="8" Margin="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
                    <TextBlock Text="选中提供器：" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedProvider.DisplayName}" Margin="6,0" VerticalAlignment="Center"/>
                    <TextBlock Text=" (配置类型: " Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SelectedProvider.ConfigType.Name}" VerticalAlignment="Center" Foreground="Gray"/>
                    <TextBlock Text=")" VerticalAlignment="Center"/>
                    <Button Content="创建实例" Command="{Binding CreateInstanceCommand}" Margin="12,0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="4">
                        <TextBlock Text="控制器配置 (JSON)" FontWeight="Bold" />
                        <TextBox Text="{Binding ControllerJson, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="260"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="4">
                        <TextBlock Text="模块配置 (JSON)" FontWeight="Bold"/>
                        <TextBox Text="{Binding ModuleJson, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="260"/>
                    </StackPanel>

                    <!-- Instances operations -->
                    <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Margin="4,276,4,4" HorizontalAlignment="Left">
                        <TextBlock Text="实例操作：" VerticalAlignment="Center" Margin="0,4"/>
                    </StackPanel>

                    <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Margin="4,306,4,4" HorizontalAlignment="Left">
                        <ItemsControl ItemsSource="{Binding Instances}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="{Binding InstanceName}" Width="180"/>
                                        <Button Content="初始化" Command="{Binding DataContext.InitializeInstanceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="4,0"/>
                                        <Button Content="关闭" Command="{Binding DataContext.ShutdownInstanceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="4,0"/>
                                        <Button Content="移除" Command="{Binding DataContext.RemoveInstanceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="4,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>