<UserControl x:Class="TangerineAutomationSystem.Views.Controls.NodifyHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TangerineAutomationSystem.Views.Controls"
             xmlns:vm="clr-namespace:TangerineAutomationSystem.ViewModels"
             x:Name="Root">
    <UserControl.DataContext>
        <vm:ProcessEditorViewModel />
    </UserControl.DataContext>
    <Grid>
        <!-- Nodify integration adapter: if Nodify is available at runtime, adapter will use it via reflection. Otherwise fallback to simple Canvas-based node host -->
        <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" x:Name="PART_ScrollViewer">
                    <Canvas x:Name="PART_Canvas" Background="Transparent" Width="2400" Height="1800">
                        <Canvas.RenderTransform>
                            <ScaleTransform x:Name="PART_ScaleTransform" ScaleX="1" ScaleY="1" />
                        </Canvas.RenderTransform>
                        
                        <!-- Draw connections first (behind nodes) -->
                        <ItemsControl ItemsSource="{Binding Connections}" x:Name="PART_Connections">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Line Stroke="#FF666666" StrokeThickness="2" 
                                          X1="{Binding FromX}" Y1="{Binding FromY}"
                                          X2="{Binding ToX}" Y2="{Binding ToY}"
                                          StrokeDashArray="2,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Draw nodes on top -->
                        <ItemsControl ItemsSource="{Binding Nodes}" x:Name="PART_Items">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style>
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderThickness="2" Padding="8" CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="PlatformTask">
                                                        <Setter Property="BorderBrush" Value="#FF4A90E2" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="ModuleAction">
                                                        <Setter Property="BorderBrush" Value="#FF7ED321" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Transfer">
                                                        <Setter Property="BorderBrush" Value="#FFF5A623" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Resource">
                                                        <Setter Property="BorderBrush" Value="#FF9013FE" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                                <Setter Property="BorderBrush" Value="#FFCCDDEE" />
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="{Binding Kind}" Foreground="Gray" FontSize="11" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </ScrollViewer>

                <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Left" Margin="4">
                    <Button Content="Add Node" Click="AddNode_Click" Style="{StaticResource ProcessToolboxButton}" />
                    <Button Content="Add Platform Task" Click="AddPlatformTaskNode_Click" Style="{StaticResource ProcessToolboxButton}" />
                    <Button Content="Add Transfer" Click="AddTransferNode_Click" Style="{StaticResource ProcessToolboxButton}" />
                    <Button Content="Add Module Action" Click="AddModuleActionNode_Click" Style="{StaticResource ProcessToolboxButton}" />
                    <Button Content="Auto-Layout" Click="AutoLayout_Click" Style="{StaticResource ProcessToolboxButton}" />
                    <Separator Margin="8,0" />
                    <Button Content="Zoom In" Click="ZoomIn_Click" Style="{StaticResource ProcessToolboxButton}" />
                    <Button Content="Zoom Out" Click="ZoomOut_Click" Style="{StaticResource ProcessToolboxButton}" />
                    <Button Content="Reset Zoom" Click="ResetZoom_Click" Style="{StaticResource ProcessToolboxButton}" />
                    <TextBlock Text="{Binding ElementName=PART_ScaleTransform, Path=ScaleX, StringFormat=Zoom: {0:P0}}" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
