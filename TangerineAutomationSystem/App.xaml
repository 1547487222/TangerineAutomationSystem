<Application x:Class="TangerineAutomationSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:conv="clr-namespace:TangerineAutomationSystem.Converters"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="DeepPurple" SecondaryColor="Lime" />

                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="/TangerineAutomationSystem;component/Styles/ThemeOverrides.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:NodeTypeToVisibilityConverter x:Key="NodeTypeToVisibility"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>