<Window x:Class="TangerineAutomationSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:local="clr-namespace:TangerineAutomationSystem"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TangerineAutomationSystem.Views"
        xmlns:vm="clr-namespace:TangerineAutomationSystem.ViewModels"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Tangerine 自动化解决方案管理" Height="760" Width="1200"
        md:ColorZoneAssist.Mode="PrimaryDark">
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <DockPanel>
        <ToolBar DockPanel.Dock="Top" Background="{DynamicResource PrimaryHueMidBrush}" Height="46">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding AddProjectCommand}" Margin="6,6">添加项目</Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding OpenProjectCommand}" Margin="6,6">打开项目</Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding SaveProjectCommand}" Margin="6,6">保存项目</Button>
                <Separator Margin="10,0"/>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding AddNodeCommand}" Margin="6,6">添加</Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding DeleteNodeCommand}" Margin="6,6">删除</Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding RenameNodeCommand}" Margin="6,6">重命名</Button>
            </StackPanel>
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" Margin="8" Padding="6" Background="White">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="解决方案资源管理器" FontWeight="Bold" FontSize="14" Margin="6"/>
                    <views:SolutionExplorer />
                </DockPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" Margin="8" Padding="12" Background="White">
                <ContentControl Content="{Binding SelectedNode}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:TreeNodeViewModel}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="节点类型：" Foreground="Gray" Margin="0,6,0,12"/>
                                    <!-- same content as before, omitted for brevity -->
                                    <StackPanel Visibility="{Binding NodeType, Converter={StaticResource NodeTypeToVisibility}, ConverterParameter=Module}">
                                        <TextBlock Text="模块名称" />
                                        <TextBox Text="{Binding Model.Name, Mode=TwoWay}" Margin="0,4"/>
                                        <TextBlock Text="模块类型" Margin="0,8,0,0"/>
                                        <ComboBox SelectedValue="{Binding Model.ModuleType, Mode=TwoWay}" Margin="0,4" Width="200">
                                            <ComboBoxItem Content="Default"/>
                                            <ComboBoxItem Content="H5U通用模块"/>
                                        </ComboBox>
                                        <TextBlock Text="描述" Margin="0,8,0,0"/>
                                        <TextBox Text="{Binding Model.Config.Description, Mode=TwoWay}" AcceptsReturn="True" Height="120"/>
                                        <Separator Margin="0,12"/>
                                        <TextBlock Text="模块编辑器" FontWeight="SemiBold" Margin="0,8"/>
                                        <views:ModuleEditor DataContext="{Binding Model}" Margin="0,8"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>