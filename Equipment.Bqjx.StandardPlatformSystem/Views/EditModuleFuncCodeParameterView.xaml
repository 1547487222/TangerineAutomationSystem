<mah:MetroWindow
    x:Class="Equipment.Bqjx.StandardPlatformSystem.Views.EditModuleFuncCodeParameterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Models"
    Title="编辑参数"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <mah:MetroWindow.Resources>

        <converters:StringToFloatConverter x:Key="StringToFloatConverter" />

        <DataTemplate DataType="{x:Type models:FuncCodeItemModel}">
            <Grid>
                <Border
                    Width="210"
                    Margin="5"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="4">

                    <StackPanel Margin="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="名称:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding ParameterName, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                ToolTip="参数名" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="描述:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding ParameterDescription, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                ToolTip="描述" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="地址:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding ParameterAddress, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="地址" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="数值:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding ParameterValue}"
                                ToolTip="数值" />
                        </StackPanel>



                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="单位:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding ParameterUnit, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="单位" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="下限:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding ParameterMinValue, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="下限" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="上限:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding ParameterMaxValue, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="上限" />
                        </StackPanel>
                        <!--  参数反馈值地址  -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="反馈地址:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding ParameterFeedbackAddress, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="反馈地址" />
                        </StackPanel>
                        <!--  参数反馈预设值  -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="反馈预设值:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding ParameterFeedbackDefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="反馈预设值" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding RelativeSource={RelativeSource AncestorLevel=1, AncestorType=ItemsControl}, Path=DataContext.DeleteItemCommand}"
                    CommandParameter="{Binding}"
                    FontSize="20"
                    Style="{StaticResource MahApps.Styles.Button.Circle}">
                    <materialDesign:PackIcon Foreground="Red" Kind="CloseCircle" />
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:MonitorInfoItemModel}">
            <Grid>
                <Border
                    Width="210"
                    Margin="5"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel Margin="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="监控名称:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding MonitorName, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                ToolTip="监控名称" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="监控地址:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding MonitorAddress, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="监控地址" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="监控描述:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding MonitorDescription, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="监控描述" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding RelativeSource={RelativeSource AncestorLevel=1, AncestorType=ItemsControl}, Path=DataContext.DeleteItemCommand}"
                    CommandParameter="{Binding}"
                    FontSize="20"
                    Style="{StaticResource MahApps.Styles.Button.Circle}">
                    <materialDesign:PackIcon Foreground="Red" Kind="CloseCircle" />
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:EbrInfoItemModel}">
            <Grid>
                <Border
                    Width="210"
                    Margin="5"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel Margin="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="EBR名称:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding EbrName, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                ToolTip="EBR名称" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="EBR描述:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding EbrDescription, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                ToolTip="EBR描述" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="模块通道:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding EbrmoduleChannel, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="EBR类型:" />
                            <ComboBox ItemsSource="{Binding EbrTypes}" SelectedItem="{Binding EbrType}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="EBR单位:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding EbrUnit, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="EBR地址:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding EbrAddress, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="EBR地址" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="EBR字符长度:" />
                            <TextBox
                                Width="50"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding CharacterLength, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                    </StackPanel>
                </Border>
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding RelativeSource={RelativeSource AncestorLevel=1, AncestorType=ItemsControl}, Path=DataContext.DeleteItemCommand}"
                    CommandParameter="{Binding}"
                    FontSize="20"
                    Style="{StaticResource MahApps.Styles.Button.Circle}">
                    <materialDesign:PackIcon Foreground="Red" Kind="CloseCircle" />
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:PrecisionInfoItemModel}">
            <Grid>
                <Border
                    Width="210"
                    Margin="5"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="4">

                    <StackPanel Margin="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="精度名称:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding PrecisionName, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                ToolTip="精度名称" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="精度真值:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding PrecisionStandardValue}"
                                TextWrapping="Wrap"
                                ToolTip="精度真值" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="精度地址:" />
                            <TextBox
                                Width="150"
                                Margin="0,4,0,2"
                                VerticalAlignment="Center"
                                Text="{Binding PrecisionAddress, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="精度地址" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding RelativeSource={RelativeSource AncestorLevel=1, AncestorType=ItemsControl}, Path=DataContext.DeleteItemCommand}"
                    CommandParameter="{Binding}"
                    FontSize="20"
                    Style="{StaticResource MahApps.Styles.Button.Circle}">
                    <materialDesign:PackIcon Foreground="Red" Kind="CloseCircle" />
                </Button>
            </Grid>
        </DataTemplate>
    </mah:MetroWindow.Resources>
    <Grid>
        <Border
            Padding="10"
            BorderBrush="#3C5A76"
            BorderThickness="1">
            <DockPanel>
                <StackPanel
                    Margin="0,8,0,0"
                    HorizontalAlignment="Left"
                    DockPanel.Dock="Top"
                    Orientation="Horizontal">
                    <Button
                        Command="{Binding ImportItemCommand}"
                        Content="导入参数"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <Button
                        Margin="8,0,8,0"
                        Command="{Binding InsertItemCommand}"
                        Content="添加参数"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <Button
                        Margin="0,8"
                        Command="{Binding ExportItemCommand}"
                        Content="导出CSV"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Datas}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>
    </Grid>
</mah:MetroWindow>
