<mah:MetroWindow
    x:Class="Equipment.Bqjx.StandardPlatformSystem.Views.ModuleParamterTableView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
    xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Icon="../Images/tangerine.ico"
    IconBitmapScalingMode="HighQuality"
    OverrideDefaultWindowCommandsBrush="White"
    ResizeMode="CanResizeWithGrip"
    Style="{StaticResource MaterialDesignWindow}"
    TitleForeground="White"
    mc:Ignorable="d">
    <Grid>
        <DockPanel LastChildFill="True">
            <ToolBar DockPanel.Dock="Top">
                <Button Command="{Binding AddModuleInfoTableCommand}" Content="添加模块信息" />
            </ToolBar>
            <!--  模块信息表  -->
            <DataGrid ItemsSource="{Binding ModuleInfoTables}" />

            <!--  模块功能码表  -->
            <DataGrid ItemsSource="{Binding}" />
        </DockPanel>
    </Grid>
</mah:MetroWindow>
