<UserControl
    x:Class="Equipment.Bqjx.StandardPlatformSystem.Views.FlowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="clr-namespace:Equipment.Bqjx.StandardPlatformSystem"
    xmlns:attachs="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Depends"
    xmlns:behaviors="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Behaviors"
    xmlns:control="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Controls"
    xmlns:converters="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:handycontrols="https://handyorg.github.io/handycontrol"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
    xmlns:o="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
    xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <app:BindingProxy x:Key="EditorProxy" DataContext="{Binding}" />
            <app:BindingProxy x:Key="EditorSelectedItemProxy" DataContext="{Binding SelectedNode}" />
            <converters:ToolStateToColorConverter x:Key="ToolStateToColorConverter" />

            <!--  斜线网格  -->
            <GeometryDrawing x:Key="DiagonalGridGeometry" Brush="{DynamicResource GridLinesBrush}">
                <GeometryDrawing.Geometry>
                    <PathGeometry Figures="M0,0 L20,20 M20,0 L0,20" />
                </GeometryDrawing.Geometry>
            </GeometryDrawing>

            <!--  网格刷子  -->
            <DrawingBrush
                x:Key="DiagonalGridBrush"
                Drawing="{StaticResource DiagonalGridGeometry}"
                Opacity="0.15"
                TileMode="Tile"
                Transform="{Binding ViewportTransform, ElementName=editor}"
                Viewport="0 0 40 40"
                ViewportUnits="Absolute" />

            <Color x:Key="GridLinesColor">#78909C</Color>
            <SolidColorBrush x:Key="GridLinesBrush" Color="{DynamicResource GridLinesColor}" />
            <Color x:Key="ContentBackgroundColor">#ECEFF1</Color>
            <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{DynamicResource ContentBackgroundColor}" />
            <LinearGradientBrush x:Key="ToolbarGradient" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#78909C" />
                <GradientStop Offset="1" Color="#607D8B" />
            </LinearGradientBrush>

            <converters:ConnectorOffsetConverter x:Key="ConnectorOffsetConverter" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Nodify;component/Themes/Light.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Border>
            <DockPanel LastChildFill="True">
                <ToolBar
                    VerticalAlignment="Top"
                    Background="{StaticResource ToolbarGradient}"
                    BorderBrush="#455A64"
                    DockPanel.Dock="Top"
                    FontFamily="Roboto Condensed">
                    <ToolBar.Resources>
                        <LinearGradientBrush x:Key="ToolbarGradient" StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#ECEFF1" />
                            <GradientStop Offset="1" Color="#CFD8DC" />
                        </LinearGradientBrush>
                        <SolidColorBrush x:Key="MenuHoverBrush" Color="#4FC3F7" />
                        <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#607D8B" />
                        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#ECEFF1" />
                    </ToolBar.Resources>

                    <!--  文件菜单  -->
                    <Menu Margin="8,0" VerticalAlignment="Center">
                        <MenuItem Background="{StaticResource MenuBackgroundBrush}" Foreground="{StaticResource MenuForegroundBrush}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Kind="FileMultipleOutline" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="文件" />
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Command="{Binding SaveFlowCommand}" Header="保存">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#4FC3F7" Kind="ContentSave" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="另存为">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#4FC3F7" Kind="ContentSave" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <!--  流程名称编辑  -->
                    <materialDesign:Card
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="#78909C"
                        BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                VerticalAlignment="Center"
                                Foreground="#263238"
                                Kind="RenameBoxOutline" />
                            <TextBox
                                x:Name="FlowNameTextBox"
                                MinWidth="150"
                                MinHeight="40"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                materialDesign:TextFieldAssist.TextBoxLineCount="1"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Roboto Condensed"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="#263238"
                                Text="{Binding FlowName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!--  流程控制菜单  -->
                    <Menu Margin="8,0" VerticalAlignment="Center">
                        <MenuItem Background="{StaticResource MenuBackgroundBrush}" Foreground="{StaticResource MenuForegroundBrush}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Kind="MicrosoftXboxControllerMenu" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="流程控制" />
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Command="{Binding ClearEphemeralDataCommand}" Header="清除流程临时数据">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#4FC3F7" Kind="DeleteOutline" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Command="{Binding RequestExecutionCancelCommand}" Header="流程取消">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#4FC3F7" Kind="Cancel" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Command="{Binding RequestExecutionResetCommand}" Header="流程复位">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#4FC3F7" Kind="Autorenew" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Command="{Binding RequestPauseCommand}" Header="流程暂停">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#4FC3F7" Kind="PauseCircleOutline" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Command="{Binding RequestPauseResetCommand}" Header="流程继续">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#4FC3F7" Kind="PlayCircleOutline" />
                                </MenuItem.Icon>
                            </MenuItem>

                        </MenuItem>
                    </Menu>

                    <!--  流程数据菜单  -->
                    <Menu Margin="8,0" VerticalAlignment="Center">
                        <MenuItem Background="{StaticResource MenuBackgroundBrush}" Foreground="{StaticResource MenuForegroundBrush}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Kind="DatabaseOutline" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="流程数据" />
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Header="数据设置">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#4FC3F7" Kind="DatabaseSettings" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="数据可视化">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#4FC3F7" Kind="TableLarge" />
                                </MenuItem.Icon>
                            </MenuItem>

                        </MenuItem>
                    </Menu>

                    <!--  设置菜单  -->
                    <Menu Margin="8,0" VerticalAlignment="Center">
                        <MenuItem Background="{StaticResource MenuBackgroundBrush}" Foreground="{StaticResource MenuForegroundBrush}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Kind="CogOutline" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="流程设置" />
                                </StackPanel>
                            </MenuItem.Header>

                        </MenuItem>
                    </Menu>

                    <!--  导出按钮  -->
                    <Button
                        Width="36"
                        Height="36"
                        Margin="8,0"
                        Background="#607D8B"
                        BorderBrush="#455A64"
                        Click="Button_Click"
                        Cursor="Hand"
                        Style="{StaticResource MaterialDesignFloatingActionButton}">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="1.2"
                                            Duration="0:0:0.3" />
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="1.2"
                                            Duration="0:0:0.3" />
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.(TransformGroup.Children)[1].(RotateTransform.Angle)"
                                            To="360"
                                            Duration="0:0:0.5" />
                                        <ColorAnimation
                                            Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                            To="#4FC3F7"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                            To="1"
                                            Duration="0:0:0.3" />
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                            To="1"
                                            Duration="0:0:0.3" />
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.(TransformGroup.Children)[1].(RotateTransform.Angle)"
                                            To="0"
                                            Duration="0:0:0.5" />
                                        <ColorAnimation
                                            Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                            To="#607D8B"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                                <RotateTransform Angle="0" CenterX="18" CenterY="18" />
                            </TransformGroup>
                        </Button.RenderTransform>
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            Foreground="#ECEFF1"
                            Kind="Import" />
                    </Button>
                </ToolBar>
                <Border>
                    <materialDesign:DrawerHost
                        x:Name="DrawerHost"
                        DrawerOpened="DrawerHost_DrawerOpened"
                        IsLeftDrawerOpen="{Binding IsLeftDrawerOpenForNodePropertyPanel}">
                        <Grid>
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#ECEFF1" />
                                    <GradientStop Offset="1" Color="#CFD8DC" />
                                </LinearGradientBrush>
                            </Grid.Background>
                            <Grid>
                                <Grid.Background>
                                    <DrawingBrush
                                        Drawing="{StaticResource DiagonalGridGeometry}"
                                        Opacity="0.15"
                                        TileMode="Tile"
                                        Viewport="0 0 40 40"
                                        ViewportUnits="Absolute" />
                                </Grid.Background>
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    AutoReverse="True"
                                                    RepeatBehavior="Forever"
                                                    Storyboard.TargetProperty="(Grid.Background).(LinearGradientBrush.Opacity)"
                                                    From="0.8"
                                                    To="1"
                                                    Duration="0:0:2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>
                            </Grid>
                            <ScrollViewer
                                x:Name="scrollViewer"
                                Grid.Column="1"
                                HorizontalScrollBarVisibility="Hidden"
                                PreviewKeyDown="ScrollViewer_PreviewKeyDown"
                                VerticalScrollBarVisibility="Hidden">
                                <DockPanel Grid.Column="1">
                                    <materialDesign:Card Background="Transparent">
                                        <Grid>
                                            <nodify:NodifyEditor
                                                x:Name="editor"
                                                ConnectionCompletedCommand="{Binding CreateConnectionCommand}"
                                                Connections="{Binding Connections}"
                                                ItemsSource="{Binding Nodes}"
                                                PendingConnection="{Binding PendingConnection}"
                                                SelectedItem="{Binding SelectedNode}">
                                                <i:Interaction.Behaviors>
                                                    <behaviors:LinkNodeDragDropBehavior DropCommand="{Binding NodeDropCommand}" DropPoint="{Binding DropPoint, Mode=TwoWay}" />
                                                </i:Interaction.Behaviors>
                                                <nodify:NodifyEditor.Background>
                                                    <DrawingBrush
                                                        Drawing="{StaticResource DiagonalGridGeometry}"
                                                        Opacity="0.15"
                                                        TileMode="Tile"
                                                        Viewport="0 0 40 40"
                                                        ViewportUnits="Absolute" />
                                                </nodify:NodifyEditor.Background>

                                                <nodify:NodifyEditor.PendingConnectionTemplate>
                                                    <DataTemplate>
                                                        <nodify:PendingConnection
                                                            EnablePreview="False"
                                                            Source="{Binding Source, Mode=OneWayToSource}"
                                                            Stroke="#546E7A"
                                                            StrokeDashArray="3,1,2,2"
                                                            StrokeThickness="2"
                                                            Target="{Binding Target, Mode=OneWayToSource}">
                                                            <nodify:PendingConnection.Template>
                                                                <ControlTemplate TargetType="{x:Type nodify:PendingConnection}">
                                                                    <nodify:Connection
                                                                        Source="{TemplateBinding SourceAnchor}"
                                                                        SourceOffsetMode="Edge"
                                                                        Spacing="0"
                                                                        Stroke="#546E7A"
                                                                        StrokeDashArray="{TemplateBinding StrokeDashArray}"
                                                                        StrokeThickness="{TemplateBinding StrokeThickness}"
                                                                        Target="{TemplateBinding TargetAnchor}"
                                                                        TargetOffsetMode="Rectangle" />
                                                                </ControlTemplate>
                                                            </nodify:PendingConnection.Template>
                                                        </nodify:PendingConnection>
                                                    </DataTemplate>
                                                </nodify:NodifyEditor.PendingConnectionTemplate>
                                                <nodify:NodifyEditor.ConnectionTemplate>
                                                    <DataTemplate>
                                                        <nodify:Connection
                                                            ArrowEnds="Both"
                                                            ArrowShape="Arrowhead"
                                                            OutlineThickness="5"
                                                            Source="{Binding Source.Anchor}"
                                                            SourceOffset="{Binding Source.Size, Converter={StaticResource ConnectorOffsetConverter}, ConverterParameter=7}"
                                                            SourceOffsetMode="Circle"
                                                            Spacing="0"
                                                            Stroke="#607D8B"
                                                            StrokeThickness="3"
                                                            Tag="{Binding}"
                                                            Target="{Binding Target.Anchor}"
                                                            TargetOffset="{Binding Target.Size, Converter={StaticResource ConnectorOffsetConverter}, ConverterParameter=7}"
                                                            TargetOffsetMode="Circle">
                                                            <nodify:Connection.Style>
                                                                <Style BasedOn="{StaticResource {x:Type nodify:Connection}}" TargetType="{x:Type nodify:Connection}">
                                                                    <Setter Property="OutlineBrush" Value="Transparent" />
                                                                    <Setter Property="StrokeThickness" Value="3" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                            <Setter Property="StrokeThickness" Value="4" />
                                                                            <Setter Property="Stroke" Value="#0288D1" />
                                                                            <Setter Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect
                                                                                        BlurRadius="8"
                                                                                        Opacity="0.7"
                                                                                        ShadowDepth="0"
                                                                                        Color="#455A64" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="OutlineBrush">
                                                                                <Setter.Value>
                                                                                    <SolidColorBrush Opacity="0.5" Color="#0288D1" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </nodify:Connection.Style>
                                                            <nodify:Connection.ContextMenu>
                                                                <ContextMenu DataContext="{Binding DataContext, Source={StaticResource EditorProxy}}">
                                                                    <MenuItem
                                                                        Command="{Binding DeleteConnecttionCommand}"
                                                                        CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                        Header="_Delete" />
                                                                </ContextMenu>
                                                            </nodify:Connection.ContextMenu>
                                                        </nodify:Connection>
                                                    </DataTemplate>
                                                </nodify:NodifyEditor.ConnectionTemplate>
                                                <nodify:NodifyEditor.ItemTemplate>
                                                    <DataTemplate>
                                                        <control:LinkNode
                                                            Content="{Binding}"
                                                            Focusable="True"
                                                            Input="{Binding InputPort, Mode=TwoWay}"
                                                            IsTabStop="True"
                                                            Output="{Binding OutputPort, Mode=TwoWay}">
                                                            <control:LinkNode.ToolTip>
                                                                <ToolTip>
                                                                    <StackPanel>
                                                                        <TextBlock
                                                                            FontFamily="Roboto Condensed"
                                                                            FontSize="14"
                                                                            Foreground="#37474F"
                                                                            Text="{Binding ToolDescription}" />
                                                                        <TextBlock
                                                                            FontFamily="Roboto Condensed"
                                                                            FontSize="12"
                                                                            Foreground="#0288D1"
                                                                            Text="{Binding ToolState}" />
                                                                    </StackPanel>
                                                                </ToolTip>
                                                            </control:LinkNode.ToolTip>
                                                        </control:LinkNode>
                                                    </DataTemplate>
                                                </nodify:NodifyEditor.ItemTemplate>

                                                <nodify:NodifyEditor.ItemContainerStyle>
                                                    <Style TargetType="{x:Type nodify:ItemContainer}">
                                                        <Setter Property="BorderBrush" Value="#455A64" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="SelectedBrush" Value="#4FC3F7" />
                                                        <Setter Property="SelectedBorderThickness" Value="3" />
                                                        <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="{x:Type nodify:ItemContainer}">
                                                                    <StackPanel Orientation="Vertical">
                                                                        <TextBlock
                                                                            MaxWidth="200"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Top"
                                                                            FontFamily="Roboto Condensed"
                                                                            FontSize="14"
                                                                            FontStyle="Italic"
                                                                            Foreground="#37474F"
                                                                            Text="{Binding ToolDescription}"
                                                                            TextWrapping="Wrap">
                                                                            <TextBlock.Background>
                                                                                <SolidColorBrush Opacity="0.8" Color="#ECEFF1" />
                                                                            </TextBlock.Background>
                                                                        </TextBlock>
                                                                        <Border
                                                                            x:Name="Border"
                                                                            Margin="1"
                                                                            Background="Transparent"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="0">
                                                                            <ContentPresenter />
                                                                            <Border.Effect>
                                                                                <DropShadowEffect
                                                                                    BlurRadius="8"
                                                                                    Direction="270"
                                                                                    Opacity="0.4"
                                                                                    ShadowDepth="2"
                                                                                    Color="#37474F" />
                                                                            </Border.Effect>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="Location" Value="{Binding Location}" />
                                                        <Setter Property="ContextMenu">
                                                            <Setter.Value>
                                                                <ContextMenu DataContext="{Binding DataContext, Source={StaticResource EditorProxy}}">
                                                                    <MenuItem
                                                                        Command="{Binding OpenLinkNodeSettingPanelCommand}"
                                                                        CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                        Header="打开设置" />
                                                                    <MenuItem
                                                                        DataContext="{Binding DataContext, Source={StaticResource EditorSelectedItemProxy}}"
                                                                        Header="功能"
                                                                        ItemsSource="{Binding TriggerPointModels}">
                                                                        <MenuItem.ItemContainerStyle>
                                                                            <Style BasedOn="{StaticResource MaterialDesignMenuItem}" TargetType="{x:Type MenuItem}">
                                                                                <Setter Property="Header" Value="{Binding CommandName}" />
                                                                                <Setter Property="Command" Value="{Binding ToolTriggerCommand}" />
                                                                            </Style>
                                                                        </MenuItem.ItemContainerStyle>
                                                                    </MenuItem>
                                                                    <MenuItem
                                                                        Command="{Binding DeleteLinkNodeCommand}"
                                                                        CommandParameter="{Binding SelectedNode}"
                                                                        Header="删除" />
                                                                    <MenuItem
                                                                        Command="{Binding CopyNodeCommand}"
                                                                        CommandParameter="{Binding SelectedNode}"
                                                                        Header="复制" />
                                                                </ContextMenu>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsSelected" Value="True" />
                                                                    <Condition Property="IsPreviewingSelection" Value="{x:Null}" />
                                                                </MultiTrigger.Conditions>
                                                                <MultiTrigger.Setters>
                                                                    <Setter Property="BorderBrush" Value="{Binding SelectedBrush, RelativeSource={RelativeSource Self}}" />
                                                                    <Setter Property="Margin" Value="{Binding SelectedMargin, RelativeSource={RelativeSource Self}}" />
                                                                    <Setter Property="BorderThickness" Value="{Binding SelectedBorderThickness, RelativeSource={RelativeSource Self}}" />
                                                                </MultiTrigger.Setters>
                                                            </MultiTrigger>
                                                            <Trigger Property="IsPreviewingSelection" Value="True">
                                                                <Setter Property="BorderBrush" Value="{Binding SelectedBrush, RelativeSource={RelativeSource Self}}" />
                                                                <Setter Property="Margin" Value="{Binding SelectedMargin, RelativeSource={RelativeSource Self}}" />
                                                                <Setter Property="BorderThickness" Value="{Binding SelectedBorderThickness, RelativeSource={RelativeSource Self}}" />
                                                                <Setter Property="BorderBrush" Value="{Binding HighlightBrush, RelativeSource={RelativeSource Self}}" />
                                                                <Setter Property="Margin" Value="{Binding SelectedMargin, RelativeSource={RelativeSource Self}}" />
                                                                <Setter Property="BorderThickness" Value="{Binding SelectedBorderThickness, RelativeSource={RelativeSource Self}}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </nodify:NodifyEditor.ItemContainerStyle>
                                                <nodify:NodifyEditor.InputBindings>
                                                    <KeyBinding
                                                        Key="Delete"
                                                        Command="{Binding DeleteLinkNodeCommand}"
                                                        CommandParameter="{Binding ElementName=editor, Path=SelectedItem}" />
                                                </nodify:NodifyEditor.InputBindings>
                                                <nodify:NodifyEditor.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Command="{Binding PasteNodeCommand}" Header="粘贴" />
                                                    </ContextMenu>
                                                </nodify:NodifyEditor.ContextMenu>
                                                <CompositeCollection />
                                            </nodify:NodifyEditor>
                                            <!--  状态指示器（环形进度条）  -->
                                            <materialDesign:Card
                                                Width="32"
                                                Height="32"
                                                Margin="8"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Bottom"
                                                Background="Transparent">
                                                <Ellipse
                                                    Width="28"
                                                    Height="28"
                                                    Fill="Transparent"
                                                    Stroke="{Binding SelectedNode.ToolState, Converter={StaticResource ToolStateToColorConverter}, FallbackValue='#78909C'}"
                                                    StrokeThickness="4">
                                                    <Ellipse.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation
                                                                        AutoReverse="True"
                                                                        RepeatBehavior="Forever"
                                                                        Storyboard.TargetProperty="Opacity"
                                                                        From="1"
                                                                        To="0.5"
                                                                        Duration="0:0:1.5" />
                                                                    <DoubleAnimation
                                                                        RepeatBehavior="Forever"
                                                                        Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                                                        From="0"
                                                                        To="360"
                                                                        Duration="0:0:2" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Ellipse.Triggers>
                                                    <Ellipse.RenderTransform>
                                                        <RotateTransform CenterX="14" CenterY="14" />
                                                    </Ellipse.RenderTransform>
                                                </Ellipse>
                                            </materialDesign:Card>
                                        </Grid>
                                    </materialDesign:Card>
                                </DockPanel>
                            </ScrollViewer>
                            <materialDesign:Card HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Border
                                    Background="Transparent"
                                    BorderBrush="#455A64"
                                    BorderThickness="0">

                                    <ListBox
                                        x:Name="MyListBox"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemsSource="{Binding NodeMenuItems}"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <i:Interaction.Behaviors>
                                            <behaviors:ListboxDoDropBehavior />
                                        </i:Interaction.Behaviors>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border
                                                                x:Name="border"
                                                                Margin="4"
                                                                Background="Transparent">
                                                                <materialDesign:Card Background="#78909C">
                                                                    <StackPanel Margin="8" Orientation="Horizontal">
                                                                        <materialDesign:PackIcon
                                                                            Width="18"
                                                                            Height="18"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="#ECEFF1"
                                                                            Kind="Tools" />
                                                                        <TextBlock
                                                                            Margin="6,0,0,0"
                                                                            VerticalAlignment="Center"
                                                                            FontFamily="Roboto Condensed"
                                                                            FontSize="15"
                                                                            Foreground="#ECEFF1"
                                                                            Text="{Binding Name}" />
                                                                    </StackPanel>
                                                                    <materialDesign:Card.Triggers>
                                                                        <EventTrigger RoutedEvent="MouseEnter">
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                                                                        To="5"
                                                                                        Duration="0:0:0.3" />
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetProperty="Opacity"
                                                                                        To="0.9"
                                                                                        Duration="0:0:0.3" />
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </EventTrigger>
                                                                        <EventTrigger RoutedEvent="MouseLeave">
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                                                                        To="0"
                                                                                        Duration="0:0:0.3" />
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetProperty="Opacity"
                                                                                        To="1"
                                                                                        Duration="0:0:0.3" />
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </EventTrigger>
                                                                    </materialDesign:Card.Triggers>
                                                                    <materialDesign:Card.RenderTransform>
                                                                        <RotateTransform CenterX="50" CenterY="20" />
                                                                    </materialDesign:Card.RenderTransform>
                                                                </materialDesign:Card>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <!--  ⭐ 高亮显示选中状态  -->
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#546E7A" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>

                                    </ListBox>
                                </Border>
                            </materialDesign:Card>

                        </Grid>
                        <materialDesign:DrawerHost.Style>
                            <Style BasedOn="{StaticResource {x:Type materialDesign:DrawerHost}}" TargetType="materialDesign:DrawerHost">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLeftDrawerOpenForNodePropertyPanel}" Value="True">
                                        <Setter Property="OverlayBackground" Value="#78909C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:DrawerHost.Style>
                        <materialDesign:DrawerHost.LeftDrawerContent>
                            <local:NodeSettingPanel DataContext="{Binding DataContext, Source={StaticResource EditorSelectedItemProxy}}" />
                        </materialDesign:DrawerHost.LeftDrawerContent>
                    </materialDesign:DrawerHost>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>