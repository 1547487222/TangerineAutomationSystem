<mah:MetroWindow x:Class="Equipment.Bqjx.StandardPlatformSystem.Views.TemplateCodeGenerationEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
        xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="模板代码编辑器" Height="600" Width="900" Icon="../Images/tangerine.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧面板 -->
        <DockPanel Grid.Column="0" LastChildFill="True" Background="WhiteSmoke">
            <WrapPanel DockPanel.Dock="Top" Margin="5">
                <Button Command="{Binding AddGenerateEditorCommand}" Content="增加" Margin="2"/>
                <Button Command="{Binding SaveGenerateEditorCommand}" Content="保存" Margin="2"/>
            </WrapPanel>

            <ListBox x:Name="listBox"
                     ItemsSource="{Binding GenerateEditorModels}"
                     BorderBrush="LightGray"
                     BorderThickness="1"
                     Background="White">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontSize="17" Text="{Binding BqjxModuleMakeName}" Margin="5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- 拖动栏 -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      Background="Gray"
                      HorizontalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" />

        <!-- 右侧内容 -->
        <ContentControl Grid.Column="2"
                        Content="{Binding ElementName=listBox, Path=SelectedItem.Content}"
                        DataContext="{Binding ElementName=listBox, Path=SelectedItem}"
                        Padding="10"
                        Background="White"
                        BorderBrush="LightGray"
                        BorderThickness="1"/>
    </Grid>
</mah:MetroWindow>
