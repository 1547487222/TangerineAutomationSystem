<Window
    x:Class="Equipment.Bqjx.StandardPlatformSystem.Views.StepOrderEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="节点排序编辑"
    Width="1000"
    Height="600"
    MinWidth="800"
    MinHeight="400"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="15" Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="8*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!--  Left Steps List  -->
        <Border
            Grid.Column="0"
            Margin="0,0,10,0"
            Background="White"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="5">
            <ListBox
                x:Name="LeftStepsListBox"
                Margin="10"
                BorderThickness="0"
                Style="{StaticResource MaterialDesignNavigationListBox}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                            Padding="5"
                            FontSize="16"
                            Text="{Binding DisplayName}"
                            ToolTip="拖动以重新排序" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!--  Right Steps List and Inputs  -->
        <Border
            Grid.Column="1"
            Margin="10,0,0,0"
            Background="White"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="5">
            <StackPanel Margin="10">
                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                    <TextBlock
                        Width="120"
                        Margin="5,0,5,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="流程任务编号" />
                    <TextBox
                        x:Name="ProcessTaskIdTextBox"
                        MinWidth="250"
                        Margin="5"
                        Padding="5"
                        VerticalContentAlignment="Center"
                        FontSize="14"
                        TextChanged="ProcessTaskIdTextBox_TextChanged"
                        ToolTip="输入流程任务编号" />
                </StackPanel>
                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                    <TextBlock
                        Width="120"
                        Margin="5,0,5,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="流程任务描述" />
                    <TextBox
                        x:Name="ProcessTaskDescTextBox"
                        MinWidth="250"
                        Margin="5"
                        Padding="5"
                        VerticalContentAlignment="Center"
                        FontSize="14"
                        TextChanged="ProcessTaskDescTextBox_TextChanged"
                        ToolTip="输入流程任务描述" />
                </StackPanel>
                <ListBox
                    x:Name="RightStepsListBox"
                    BorderThickness="0"
                    Height="800"
                    Style="{StaticResource MaterialDesignListBox}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,2"
                                Background="#FAFAFA"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="3">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="5"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="{Binding DisplayName}" />
                                    <Button
                                        Margin="5,0"
                                        Padding="8,4"
                                        HorizontalAlignment="Right"
                                        Background="#FF5252"
                                        BorderThickness="0"
                                        Click="DeleteStepButton_Click"
                                        Content="删除"
                                        Foreground="White"
                                        Style="{StaticResource MahApps.Styles.Button.Flat}"
                                        ToolTip="删除此步骤" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </StackPanel>
        </Border>

        <!--  Add Button  -->
        <Button
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Width="120"
            Height="40"
            Margin="0,10"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Background="#2196F3"
            BorderThickness="0"
            Click="AddStepButton_Click"
            Content="添加步骤"
            FontSize="14"
            Foreground="White"
            Style="{StaticResource MahApps.Styles.Button.Flat}"
            ToolTip="添加新步骤" />
    </Grid>
</Window>