<mah:MetroWindow
    x:Class="Equipment.Bqjx.StandardPlatformSystem.Views.GrpcProjectGenerateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="gRPC 项目生成器"
    Width="1200"
    Height="700"
    materialDesign:ColorZoneAssist.Mode="PrimaryLight"
    Icon="../Images/tangerine.ico"
    IconBitmapScalingMode="HighQuality"
    OverrideDefaultWindowCommandsBrush="White"
    ResizeMode="CanResizeWithGrip"
    Style="{StaticResource MaterialDesignWindow}"
    TitleForeground="White">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <DockPanel Margin="10" LastChildFill="True">

            <!--  顶部工具栏  -->
            <ToolBar DockPanel.Dock="Top" Style="{StaticResource MaterialDesignToolBar}">
                <Button
                    Padding="10,4"
                    Command="{Binding AddProjectCommand}"
                    Content="➕ 创建新项目"
                    FontSize="16"
                    Style="{StaticResource MaterialDesignFlatButton}" />
            </ToolBar>

            <!--  左侧项目列表  -->
            <Border
                Width="200"
                Margin="0,0,10,0"
                Padding="10"
                Background="White"
                CornerRadius="8"
                DockPanel.Dock="Left">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="18"
                        FontWeight="Bold"
                        Text="项目列表" />
                    <ListBox
                        x:Name="list"
                        ItemsSource="{Binding Projects}"
                        Style="{StaticResource MaterialDesignListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,8,0"
                                        Foreground="{DynamicResource MaterialDesignDarkSeparatorBackground}"
                                        Kind="FolderOpen" />
                                    <StackPanel>
                                        <TextBlock
                                            MaxWidth="90"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource MaterialDesignShadowBrush}"
                                            Text="{Binding SolutionName}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            MaxWidth="90"
                                            FontSize="12"
                                            Foreground="Gray"
                                            Text="{Binding ProjectName}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBox}, Path=DataContext.RemoveProjectCommand}" CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="FontSize" Value="18" />
                                                <Setter Property="Margin" Value="5" />
                                                <Setter Property="Foreground" Value="Red" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </Button.Style>
                                        ❌
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!--  右侧内容区域  -->
            <Border
                Padding="10"
                Background="White"
                CornerRadius="8">
                <ScrollViewer
                    CanContentScroll="True"
                    HorizontalScrollBarVisibility="Hidden"
                    VerticalScrollBarVisibility="Visible">
                    <ContentControl Content="{Binding ElementName=list, Path=SelectedItem.View}" />
                </ScrollViewer>
            </Border>

        </DockPanel>
    </Grid>
</mah:MetroWindow>
