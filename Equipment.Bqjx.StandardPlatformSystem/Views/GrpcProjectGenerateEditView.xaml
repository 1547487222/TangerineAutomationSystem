<UserControl
    x:Class="Equipment.Bqjx.StandardPlatformSystem.Views.GrpcProjectGenerateEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Converters"
    xmlns:handycontrol="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    x:Name="this">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml" />
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.MahApps;component/Themes/MaterialDesignTheme.MahApps.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:PtrToVisibilityConverter x:Key="PtrToVisibilityConverter" />
            <converters:PlatformSelectManyConverter x:Key="PlatformSelectManyConverter" />
        </ResourceDictionary>

    </UserControl.Resources>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <ScrollViewer
            Width="1250"
            Height="2000"
            Margin="10"
            CanContentScroll="True"
            HorizontalScrollBarVisibility="Visible">
            <TabControl Style="{StaticResource MaterialDesignTabControl}">
                <TabItem Header="编辑项目">
                    <StackPanel>

                        <!--  Header gRPC 项目生成器  -->
                        <TextBlock
                            Margin="0,0,0,20"
                            FontSize="26"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource DarkPrimaryBrush}"
                            Text="gRPC 项目生成器" />

                        <!--  项目名称  -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="项目名称：" />
                            <TextBox
                                Grid.Column="1"
                                Height="40"
                                VerticalContentAlignment="Center"
                                FontSize="16"
                                Style="{StaticResource MahApps.Styles.TextBox}"
                                Text="{Binding Model.ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextAlignment="Left" />
                        </Grid>

                        <!--  解决方案位置  -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="解决方案位置：" />
                            <TextBox
                                Grid.Column="1"
                                Height="40"
                                VerticalContentAlignment="Center"
                                FontSize="16"
                                Style="{StaticResource MahApps.Styles.TextBox}"
                                Text="{Binding Model.SolutionRootPath, UpdateSourceTrigger=PropertyChanged}"
                                TextAlignment="Left" />
                            <Button
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                Command="{Binding SelectSolutionRootPathCommand}"
                                Style="{StaticResource MaterialDesignIconButton}">
                                <materialDesign:PackIcon
                                    Width="24"
                                    Height="24"
                                    Kind="FolderOpen" />
                            </Button>
                        </Grid>

                        <!--  解决方案名称  -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="解决方案名称：" />
                            <TextBox
                                Grid.Column="1"
                                Height="40"
                                VerticalContentAlignment="Center"
                                FontSize="16"
                                Style="{StaticResource MahApps.Styles.TextBox}"
                                Text="{Binding Model.SolutionName, UpdateSourceTrigger=PropertyChanged}"
                                TextAlignment="Left" />
                        </Grid>

                        <!--  实验室名称  -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="实验室名称：" />
                            <TextBox
                                Grid.Column="1"
                                Height="40"
                                VerticalContentAlignment="Center"
                                FontSize="16"
                                Style="{StaticResource MahApps.Styles.TextBox}"
                                Text="{Binding Model.LaboratoryName, UpdateSourceTrigger=PropertyChanged}"
                                TextAlignment="Left" />
                        </Grid>

                        <!--  实验室编号  -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="实验室编号：" />
                            <TextBox
                                Grid.Column="1"
                                Height="40"
                                VerticalContentAlignment="Center"
                                FontSize="16"
                                Style="{StaticResource MahApps.Styles.TextBox}"
                                Text="{Binding Model.LaboratoryCode, UpdateSourceTrigger=PropertyChanged}"
                                TextAlignment="Left" />
                        </Grid>

                        <!--  实验室描述  -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="实验室描述：" />
                            <TextBox
                                Grid.Column="1"
                                Height="40"
                                VerticalContentAlignment="Center"
                                FontSize="16"
                                Style="{StaticResource MahApps.Styles.TextBox}"
                                Text="{Binding Model.LaboratoryDescription, UpdateSourceTrigger=PropertyChanged}"
                                TextAlignment="Left" />
                        </Grid>


                        <!--  添加平台  -->
                        <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                            <Button
                                Margin="5"
                                Command="{Binding Model.AddPlatformCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Margin="0,0,5,0"
                                        VerticalAlignment="Center"
                                        Kind="PlusBox" />
                                    <TextBlock FontSize="16" Text="添加平台" />
                                </StackPanel>
                            </Button>
                            <Button
                                Margin="5"
                                Command="{Binding Model.DeletePlatformCommand}"
                                CommandParameter="{Binding ElementName=platfromList, Path=SelectedItem}"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Margin="0,0,5,0"
                                        VerticalAlignment="Center"
                                        Kind="MinusBox" />
                                    <TextBlock FontSize="16" Text="删除平台" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!--  平台列表 和详情  -->
                        <Grid Height="1000" Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ListBox
                                x:Name="platfromList"
                                Grid.Column="0"
                                ItemsSource="{Binding Model.PlatformCreates}"
                                Style="{StaticResource MaterialDesignListBox}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5" Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                Kind="Server" />
                                            <TextBlock Margin="10,0,0,0" Text="{Binding PlatformName}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ContentControl
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                Content="{Binding ElementName=platfromList, Path=SelectedItem.View}" />
                        </Grid>

                        <!--  中转模块  -->
                        <Border
                            Width="1200"
                            Height="500"
                            Margin="5"
                            HorizontalAlignment="Left"
                            Background="Gray"
                            CornerRadius="8">
                            <GroupBox Margin="5" Style="{StaticResource MaterialDesignCardGroupBox}">
                                <GroupBox.Header>
                                    <Grid>
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Text="中转模块" />
                                        <Grid HorizontalAlignment="Right">
                                            <UniformGrid Columns="2">
                                                <Button Command="{Binding Model.AddTransferModuleCommand}" Content="新增" />
                                                <Button
                                                    Margin="5,0,0,0"
                                                    Command="{Binding Model.DeleteTransferModuleCommand}"
                                                    CommandParameter="{Binding ElementName=TransferModuleDataGrid, Path=SelectedItem}"
                                                    Content="删除" />
                                            </UniformGrid>
                                        </Grid>
                                    </Grid>
                                </GroupBox.Header>
                                <DataGrid
                                    x:Name="TransferModuleDataGrid"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    HeadersVisibility="Column"
                                    ItemsSource="{Binding Model.TransferModules}"
                                    MinColumnWidth="100"
                                    Style="{StaticResource MaterialDesignDataGrid}"
                                    TextElement.FontSize="14">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding TransferModuleName, UpdateSourceTrigger=PropertyChanged}" Header="中转名称" />
                                        <DataGridTextColumn Binding="{Binding TransferModuleSamplingFlux, UpdateSourceTrigger=PropertyChanged}" Header="中转进样通量" />
                                        <DataGridCheckBoxColumn Binding="{Binding IsReverse, UpdateSourceTrigger=PropertyChanged}" Header="是否反转" />
                                        <DataGridTemplateColumn>
                                            <DataGridTemplateColumn.Header>
                                                <TextBlock Text="中转模块信息" />
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox
                                                        DisplayMemberPath="ParameterDescription"
                                                        ItemsSource="{Binding ModuleInfoParameterModels}"
                                                        SelectedItem="{Binding TransferModuleInfoParameterModel, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn>
                                            <DataGridTemplateColumn.Header>
                                                <TextBlock Text="左平台" />
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox
                                                        DisplayMemberPath="PlatformName"
                                                        ItemsSource="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=DataContext.Model.PlatformCreates}"
                                                        SelectedItem="{Binding LeftPlatformModel, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn>
                                            <DataGridTemplateColumn.Header>
                                                <TextBlock Text="右平台" />
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox
                                                        DisplayMemberPath="PlatformName"
                                                        ItemsSource="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=DataContext.Model.PlatformCreates}"
                                                        SelectedItem="{Binding RightPlatformModel, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn>
                                            <DataGridTemplateColumn.Header>
                                                <TextBlock Text="左通道参数" />
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox
                                                        DisplayMemberPath="ParameterDescription"
                                                        ItemsSource="{Binding LeftChannelGroupParameterModels}"
                                                        SelectedItem="{Binding LeftChannelGroupParameterModel, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn>
                                            <DataGridTemplateColumn.Header>
                                                <TextBlock Text="右通道参数" />
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox
                                                        DisplayMemberPath="ParameterDescription"
                                                        ItemsSource="{Binding RightChannelGroupParameterModels}"
                                                        SelectedItem="{Binding RightChannelGroupParameterModel, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!--  正向移动参数信息  -->
                                        <DataGridTemplateColumn>
                                            <DataGridTemplateColumn.Header>
                                                <TextBlock Text="正向移动参数" />
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox
                                                        DisplayMemberPath="ParameterDescription"
                                                        ItemsSource="{Binding ForwardModuleFuncCodeInfoParameterModels}"
                                                        SelectedItem="{Binding ForwardModuleFuncCodeInfoParameterModel, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!--  反向移动参数信息  -->
                                        <DataGridTemplateColumn>
                                            <DataGridTemplateColumn.Header>
                                                <TextBlock Text="反向移动参数" />
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox
                                                        DisplayMemberPath="ParameterDescription"
                                                        ItemsSource="{Binding BackwardModuleFuncCodeInfoParameterModels}"
                                                        SelectedItem="{Binding BackwardModuleFuncCodeInfoParameterModel, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </Border>
                        <!--  添加工艺流程  -->
                        <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                            <Button
                                Margin="5"
                                Command="{Binding Model.AddProcessflowCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Margin="0,0,5,0"
                                        VerticalAlignment="Center"
                                        Kind="FlowchartOutline" />
                                    <TextBlock FontSize="16" Text="添加工艺流程" />
                                </StackPanel>
                            </Button>
                            <Button
                                Margin="5"
                                Command="{Binding Model.DeleteProcessflowCommand}"
                                CommandParameter="{Binding ElementName=platfromflowList, Path=SelectedItem}"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Margin="0,0,5,0"
                                        VerticalAlignment="Center"
                                        Kind="MinusBox" />
                                    <TextBlock FontSize="16" Text="删除工艺流程" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!--  工艺流程列表和详情  -->
                        <Grid Height="400" Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ListBox
                                x:Name="platfromflowList"
                                Grid.Column="0"
                                ItemsSource="{Binding Model.Processflows}"
                                Style="{StaticResource MaterialDesignListBox}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5" Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                Kind="Server" />
                                            <TextBlock Margin="10,0,0,0" Text="{Binding ProcessName}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Column="2" Margin="10,0,0,0">
                                <Border
                                    Margin="5"
                                    Padding="5"
                                    Background="{StaticResource RegionBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    DataContext="{Binding ElementName=platfromflowList, Path=SelectedItem}"
                                    Visibility="{Binding ElementName=platfromflowList, Path=SelectedItem, Converter={StaticResource PtrToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                                <TextBlock
                                                    Width="100"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Text="工艺流程编号：" />
                                                <TextBox
                                                    Width="300"
                                                    Height="40"
                                                    VerticalContentAlignment="Center"
                                                    AcceptsReturn="True"
                                                    FontSize="16"
                                                    Style="{StaticResource MahApps.Styles.TextBox}"
                                                    Text="{Binding ProcessCode, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                                <TextBlock
                                                    Width="100"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Text="工艺流程名称：" />
                                                <TextBox
                                                    Width="300"
                                                    Height="40"
                                                    VerticalContentAlignment="Center"
                                                    AcceptsReturn="True"
                                                    FontSize="16"
                                                    Style="{StaticResource MahApps.Styles.TextBox}"
                                                    Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                                <TextBlock
                                                    Width="100"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Text="工艺流程类型：" />
                                                <ComboBox
                                                    Width="320"
                                                    Height="40"
                                                    materialDesign:HintAssist.Hint="工艺流程类型"
                                                    FontSize="14"
                                                    ItemsSource="{Binding ProcessflowTypes}"
                                                    SelectedValue="{Binding ProcessStep, UpdateSourceTrigger=PropertyChanged}"
                                                    Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                                    ToolTip="选择工艺流程类型" />
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                                <TextBlock
                                                    Width="100"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Text="工艺流程描述：" />
                                                <TextBox
                                                    Width="300"
                                                    Height="40"
                                                    VerticalContentAlignment="Center"
                                                    AcceptsReturn="True"
                                                    FontSize="16"
                                                    Style="{StaticResource MahApps.Styles.TextBox}"
                                                    Text="{Binding ProcessDescription, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1">
                                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                                <ItemsControl
                                                    x:Name="ComboBoxplatfromList"
                                                    MinWidth="300"
                                                    MaxWidth="500"
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    FontSize="15"
                                                    ItemsSource="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=DataContext.Model.PlatformCreates}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Margin="2" Orientation="Horizontal">
                                                                <TextBlock
                                                                    Width="100"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="16"
                                                                    FontWeight="SemiBold"
                                                                    Text="{Binding PlatformName}" />
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <ComboBox
                                                                            x:Name="comBoxTaskfiles"
                                                                            MinWidth="200"
                                                                            Margin="2,0,0,0"
                                                                            ItemsSource="{Binding StartTaskFiles, Mode=TwoWay}">
                                                                            <ComboBox.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock Text="{Binding FlowTaskCode}" />
                                                                                        <TextBlock Margin="2,0,0,0" Text="{Binding FlowTaskDescription}" />
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </ComboBox.ItemTemplate>
                                                                        </ComboBox>
                                                                        <Button
                                                                            Margin="5,0,0,0"
                                                                            Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Border}, Path=DataContext.AddOrderPlatformCommand}"
                                                                            CommandParameter="{Binding ElementName=comBoxTaskfiles, Path=SelectedItem}">
                                                                            ✚
                                                                        </Button>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Button
                                                    Margin="5,0,0,0"
                                                    Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Border}, Path=DataContext.RemoveOrderPlatformCommand}"
                                                    CommandParameter="{Binding ElementName=platfromOrderList, Path=SelectedItem}">
                                                    ✖
                                                </Button>

                                            </StackPanel>
                                            <!--  平台步骤条  -->
                                            <ScrollViewer HorizontalAlignment="Left" HorizontalScrollBarVisibility="Auto">
                                                <ListBox
                                                    x:Name="platfromOrderList"
                                                    Width="950"
                                                    ItemsSource="{Binding PlatformsInOrder}">
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>

                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                                <TextBlock
                                                                    Margin="0,0,8,0"
                                                                    FontSize="15"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                    Text="{Binding FlowTaskDescription}" />
                                                                <TextBlock
                                                                    Margin="0,0,8,0"
                                                                    FontSize="16"
                                                                    Text="⟶" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Border>
                        </Grid>

                        <!--  添加产线  -->
                        <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                            <Button
                                Margin="5"
                                Command="{Binding Model.AddProductLineCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Margin="0,0,5,0"
                                        VerticalAlignment="Center"
                                        Kind="LinkBoxOutline" />
                                    <TextBlock FontSize="16" Text="添加产线" />
                                </StackPanel>
                            </Button>
                            <Button
                                Margin="5"
                                Command="{Binding Model.DeleteProductLineCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Margin="0,0,5,0"
                                        VerticalAlignment="Center"
                                        Kind="MinusBox" />
                                    <TextBlock FontSize="16" Text="删除产线" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!--  产线列表和详情  -->
                        <Grid Height="400" Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ListBox
                                x:Name="productlineList"
                                Grid.Column="0"
                                ItemsSource="{Binding Model.ProductLines}"
                                Style="{StaticResource MaterialDesignListBox}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5" Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="20"
                                                Height="20"
                                                Kind="Server" />
                                            <TextBlock Margin="10,0,0,0" Text="{Binding ProductLineName}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Column="2" Margin="10,0,0,0">
                                <Border
                                    Margin="5"
                                    Padding="5"
                                    Background="{StaticResource RegionBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    DataContext="{Binding ElementName=productlineList, Path=SelectedItem}"
                                    Visibility="{Binding ElementName=productlineList, Path=SelectedItem, Converter={StaticResource PtrToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                                <TextBlock
                                                    Width="100"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Text="产线编号：" />
                                                <TextBox
                                                    Width="300"
                                                    Height="40"
                                                    VerticalContentAlignment="Center"
                                                    AcceptsReturn="True"
                                                    FontSize="16"
                                                    Style="{StaticResource MahApps.Styles.TextBox}"
                                                    Text="{Binding ProductLineCode, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                                <TextBlock
                                                    Width="100"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Text="产线名称：" />
                                                <TextBox
                                                    Width="300"
                                                    Height="40"
                                                    VerticalContentAlignment="Center"
                                                    AcceptsReturn="True"
                                                    FontSize="16"
                                                    Style="{StaticResource MahApps.Styles.TextBox}"
                                                    Text="{Binding ProductLineName, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                                <TextBlock
                                                    Width="100"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Text="产线描述：" />
                                                <TextBox
                                                    Width="300"
                                                    Height="40"
                                                    VerticalContentAlignment="Center"
                                                    AcceptsReturn="True"
                                                    FontSize="16"
                                                    Style="{StaticResource MahApps.Styles.TextBox}"
                                                    Text="{Binding ProductLineDescription, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1">
                                            <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                                                <ComboBox
                                                    x:Name="ComboBoxProcessflowList"
                                                    MinWidth="300"
                                                    MaxWidth="500"
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    FontSize="15"
                                                    ItemsSource="{Binding ElementName=platfromflowList, Path=ItemsSource}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ProcessName}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <Button
                                                    Margin="5,0,0,0"
                                                    Command="{Binding AddOrderProcessFlowCommand}"
                                                    CommandParameter="{Binding ElementName=ComboBoxProcessflowList, Path=SelectedItem}">
                                                    ✚
                                                </Button>
                                                <Button
                                                    Margin="5,0,0,0"
                                                    Command="{Binding RemoveOrderProcessFlowCommand}"
                                                    CommandParameter="{Binding ElementName=processflowsInOrderList, Path=SelectedItem}">
                                                    ✖
                                                </Button>
                                            </StackPanel>
                                            <ScrollViewer HorizontalAlignment="Left" HorizontalScrollBarVisibility="Auto">
                                                <ListBox
                                                    x:Name="processflowsInOrderList"
                                                    Width="950"
                                                    ItemsSource="{Binding ProcessFlowsInOrder}">
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Vertical" />
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>

                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                                                                <TextBlock
                                                                    Margin="0,0,8,0"
                                                                    FontSize="15"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                    Text="{Binding ProcessName}" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Border>
                        </Grid>


                        <!--  生成按钮  -->
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Command="{Binding Model.GenerateGrpcProjectCommand}" Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Margin="0,0,5,0" Kind="PlayCircle" />
                                    <TextBlock FontSize="16" Text="生成 gRPC 项目" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
                <TabItem Header="项目调试">
                    <StackPanel>
                        <Border
                            Margin="0,0,0,10"
                            Padding="10"
                            HorizontalAlignment="Right">
                            <Button Command="{Binding Model.RunProjectCommand}" Content="运行项目" />
                        </Border>
                        <Border Margin="0,0,0,10" Padding="10">
                            <ItemsControl ItemsSource="{Binding Model.ProcessDebugs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <GroupBox
                                            Margin="0,0,0,10"
                                            Header="{Binding ProcessName}"
                                            Style="{StaticResource MaterialDesignCardGroupBox}">
                                            <ItemsControl ItemsSource="{Binding Commands}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Margin="0,0,0,10" Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10" Padding="10">
                                                            <Button Command="{Binding Command}" Content="{Binding CommandName}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </GroupBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </ScrollViewer>
    </Grid>
</UserControl>
