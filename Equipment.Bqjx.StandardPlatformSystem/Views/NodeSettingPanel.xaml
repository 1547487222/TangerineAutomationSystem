<UserControl
    x:Class="Equipment.Bqjx.StandardPlatformSystem.Views.NodeSettingPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <materialDesign:Card>
            <Border MinWidth="600">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <GroupBox materialDesign:ElevationAssist.Elevation="Dp6" Style="{StaticResource MaterialDesignGroupBox}">
                        <GroupBox.Header>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding DisplayName}" />
                        </GroupBox.Header>
                        <TabControl
                            x:Name="linknodeTabcontrol"
                            DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=DataContext}"
                            TabStripPlacement="Left">
                            <TabItem Header="基本设置">
                                <StackPanel Margin="2" Orientation="Vertical">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            Margin="4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            Foreground="Gray"
                                            Text="模块名称" />
                                        <TextBox
                                            MinWidth="200"
                                            Margin="2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="18"
                                            Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="属性管理">
                                <DockPanel LastChildFill="True">
                                    <Button
                                        Margin="0,5,0,0"
                                        Command="{Binding ApplyContextChangeCommand}"
                                        Content=" 应 用 "
                                        DockPanel.Dock="Bottom" />
                                    <xceed:PropertyGrid
                                        x:Name="propertyGrid"
                                        Foreground="Black"
                                        SelectedObject="{Binding OwnerTool.DataContext}" />
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="部件引用">
                                <ScrollViewer>
                                    <Border>
                                        <ItemsControl ItemsSource="{Binding RefPartProperties}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="2">
                                                        <GroupBox Header="{Binding OwnerRef.PropertyName}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <ComboBox
                                                                    MinWidth="250"
                                                                    HorizontalAlignment="Left"
                                                                    ItemsSource="{Binding RefPartPropertyModels}"
                                                                    MaxDropDownHeight="800"
                                                                    ScrollViewer.CanContentScroll="True"
                                                                    SelectedItem="{Binding RefPartModel}"
                                                                    Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                                                    <ComboBox.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <VirtualizingStackPanel />
                                                                        </ItemsPanelTemplate>
                                                                    </ComboBox.ItemsPanel>
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock
                                                                                    Margin="2"
                                                                                    FontSize="15"
                                                                                    Text="{Binding PartName}" />
                                                                                <TextBlock
                                                                                    Margin="2"
                                                                                    FontSize="15"
                                                                                    Text="{Binding PartDesc}" />
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                                <Button
                                                                    Margin="3,0,0,0"
                                                                    Command="{Binding UnInstallRefCommand}"
                                                                    Content="卸载引用"
                                                                    Style="{StaticResource MaterialDesignFlatMidBgButton}" />
                                                            </StackPanel>
                                                        </GroupBox>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="参数引用">
                                <ScrollViewer>
                                    <Border>
                                        <ItemsControl ItemsSource="{Binding RefParameterPropertyters}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="2">
                                                        <GroupBox>
                                                            <GroupBox.Header>
                                                                <Grid>
                                                                    <TextBlock
                                                                        Margin="2"
                                                                        HorizontalAlignment="Left"
                                                                        FontSize="15"
                                                                        Text="{Binding OwnerRef.PropertyName}" />
                                                                    <Button
                                                                        MinWidth="50"
                                                                        MaxHeight="30"
                                                                        HorizontalAlignment="Right"
                                                                        Command="{Binding RelativeSource={RelativeSource AncestorLevel=1, AncestorType=TabControl}, Path=DataContext.DeleteRefPropertyPropertyCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource MaterialDesignFlatDarkBgButton}">
                                                                        <materialDesign:PackIcon Kind="Remove" />
                                                                    </Button>
                                                                </Grid>

                                                            </GroupBox.Header>
                                                            <StackPanel Orientation="Horizontal">

                                                                <ComboBox
                                                                    MinWidth="250"
                                                                    HorizontalAlignment="Left"
                                                                    ItemsSource="{Binding Parameters}"
                                                                    MaxDropDownHeight="800"
                                                                    ScrollViewer.CanContentScroll="True"
                                                                    SelectedItem="{Binding SelectedParameter}"
                                                                    Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                                                    <ComboBox.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <VirtualizingStackPanel />
                                                                        </ItemsPanelTemplate>
                                                                    </ComboBox.ItemsPanel>
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock
                                                                                    Margin="2"
                                                                                    FontSize="15"
                                                                                    Text="{Binding ParameterDescription}" />
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </StackPanel>
                                                        </GroupBox>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="输入管理">
                                <ScrollViewer>
                                    <Border>
                                        <ItemsControl ItemsSource="{Binding InputPort.MatchConnectPins}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel>
                                                        <GroupBox Margin="5" Style="{StaticResource MaterialDesignCardGroupBox}">
                                                            <GroupBox.Header>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock
                                                                        Margin="2"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontWeight="DemiBold"
                                                                        Text="{Binding InputSourcePin.Name}"
                                                                        TextAlignment="Center" />
                                                                    <TextBlock
                                                                        Margin="2"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontWeight="DemiBold"
                                                                        Text="{Binding InputSourcePin.PinDataType.Name}"
                                                                        TextAlignment="Center" />
                                                                </StackPanel>
                                                            </GroupBox.Header>
                                                            <ItemsControl ItemsSource="{Binding OutputTargetMatchPins}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <CheckBox IsChecked="{Binding OutputMatchConnected}" />
                                                                            <TextBlock
                                                                                Margin="2"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                FontSize="15"
                                                                                Text="{Binding TargetOutputPin.OwnerToolDisplayName}"
                                                                                TextAlignment="Center" />
                                                                            <TextBlock
                                                                                Margin="2"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                FontSize="15"
                                                                                FontWeight="Black"
                                                                                Text="{Binding TargetOutputPin.Name}"
                                                                                TextAlignment="Center" />
                                                                            <TextBlock
                                                                                Margin="2"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                Text="{Binding TargetOutputPin.PinDataType.Name}"
                                                                                TextAlignment="Center" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </GroupBox>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="输出管理">
                                <ScrollViewer>
                                    <Border>
                                        <ItemsControl ItemsSource="{Binding OutputPort.MatchConnectPins}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel>
                                                        <GroupBox Margin="5" Style="{StaticResource MaterialDesignCardGroupBox}">
                                                            <GroupBox.Header>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock
                                                                        Margin="2"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontWeight="DemiBold"
                                                                        Text="{Binding OutputSourcePin.Name}"
                                                                        TextAlignment="Center" />
                                                                    <TextBlock
                                                                        Margin="2"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontWeight="DemiBold"
                                                                        Text="{Binding OutputSourcePin.PinDataType.Name}"
                                                                        TextAlignment="Center" />
                                                                </StackPanel>
                                                            </GroupBox.Header>
                                                            <ItemsControl ItemsSource="{Binding InputTargetMatchPins}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <CheckBox IsChecked="{Binding InputMatchConnected}" />
                                                                            <TextBlock
                                                                                Margin="2"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                FontSize="15"
                                                                                Text="{Binding TargetInputPin.OwnerToolDisplayName}"
                                                                                TextAlignment="Center" />
                                                                            <TextBlock
                                                                                Margin="2"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                FontSize="15"
                                                                                FontWeight="Black"
                                                                                Text="{Binding TargetInputPin.Name}"
                                                                                TextAlignment="Center" />
                                                                            <TextBlock
                                                                                Margin="2"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                Text="{Binding TargetInputPin.PinDataType.Name}"
                                                                                TextAlignment="Center" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </GroupBox>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </GroupBox>
                </Grid>
            </Border>
        </materialDesign:Card>
    </Grid>
</UserControl>
