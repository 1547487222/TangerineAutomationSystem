<mah:MetroWindow x:Class="Equipment.Bqjx.StandardPlatformSystem.Views.ScriptEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Views"
        	 xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d" 
           xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             d:DesignHeight="450" d:DesignWidth="800" Icon="../Images/tangerine.ico">
    <Grid>
        <DockPanel LastChildFill="True">
            <DockPanel  DockPanel.Dock="Bottom">
                <Button Content="编译" Command="{Binding CompileScriptCommand}" CommandParameter="{Binding ElementName=textEditor,Path=Text}" Margin="5" HorizontalAlignment="Right"/>
            </DockPanel>
            <avalonEdit:TextEditor
	Name="textEditor"
	FontFamily="Consolas"
	FontSize="10pt"
    ShowLineNumbers ="True"
	SyntaxHighlighting="C#"
>
            </avalonEdit:TextEditor>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
