<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Equipment.Bqjx.StandardPlatformSystem.Controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:nodity="clr-namespace:Nodify;assembly=Nodify">

    <Style TargetType="{x:Type controls:LinkNode}">
        <Setter Property="Width" Value="180" />
        <Setter Property="MinHeight" Value="90" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:LinkNode}">
                    <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        materialDesign:ElevationAssist.Elevation="Dp6"
                        Background="#ECEFF1"
                        BorderBrush="#455A64"
                        BorderThickness="2"
                        CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.35*" />
                                <RowDefinition Height="0.6*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" CornerRadius="4,4,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#607D8B" />
                                        <GradientStop Offset="0.5" Color="#546E7A" />
                                        <GradientStop Offset="1" Color="#37474F" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Roboto Condensed"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTip="{Binding Name}" />
                            </Border>

                            <Border Grid.Row="1" CornerRadius="0,0,4,4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#ECEFF1" />
                                        <GradientStop Offset="1" Color="#CFD8DC" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Roboto Condensed"
                                    FontSize="16"
                                    FontWeight="Medium"
                                    Foreground="#37474F"
                                    Text="{Binding DisplayName, FallbackValue='Node Description'}"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap"
                                    ToolTip="{Binding DisplayName}" />
                            </Border>

                            <Ellipse
                                x:Name="state"
                                Width="25"
                                Height="25"
                                Margin="5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Fill="#78909C"
                                Stroke="#455A64"
                                StrokeThickness="2"
                                ToolTip="{Binding ToolState}">
                            </Ellipse>

                            <ContentControl Grid.Row="0" DataContext="{TemplateBinding Input}">
                                <nodity:Connector
                                    x:Name="PART_Input"
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Top"
                                    Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                    Background="White"
                                    BorderBrush="#455A64"
                                    BorderThickness="2"
                                    FlowDirection="LeftToRight"
                                    IsConnected="True"
                                    OverridesDefaultStyle="True"
                                    RenderTransformOrigin="0.5,0.5"
                                    ToolTip="Input Connector">
                                    <nodity:Connector.RenderTransform>
                                        <TranslateTransform Y="-8" />
                                    </nodity:Connector.RenderTransform>
                                </nodity:Connector>
                            </ContentControl>

                            <ContentControl Grid.Row="1" DataContext="{TemplateBinding Output}">
                                <nodity:Connector
                                    x:Name="PART_Output"
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Bottom"
                                    Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                    Background="White"
                                    BorderBrush="#455A64"
                                    BorderThickness="2"
                                    IsConnected="True"
                                    RenderTransformOrigin="0.5,0.5"
                                    ToolTip="Output Connector">
                                    <nodity:Connector.RenderTransform>
                                        <TranslateTransform Y="8" />
                                    </nodity:Connector.RenderTransform>
                                </nodity:Connector>
                            </ContentControl>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding ToolState}" Value="None">
                            <Setter TargetName="state" Property="Fill" Value="#78909C" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToolState}" Value="Error">
                            <Setter TargetName="state" Property="Fill" Value="#D32F2F" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToolState}" Value="Finish">
                            <Setter TargetName="state" Property="Fill" Value="#388E3C" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToolState}" Value="Running">
                            <Setter TargetName="state" Property="Fill" Value="#0288D1" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToolState}" Value="Forewarn">
                            <Setter TargetName="state" Property="Fill" Value="#F57C00" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToolState}" Value="SyncWaiting">
                            <Setter TargetName="state" Property="Fill" Value="#FFCA28" />
                        </DataTrigger>
                        <Trigger SourceName="PART_Input" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Input" Property="Background" Value="#78909C" />
                        </Trigger>
                        <Trigger SourceName="PART_Output" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Output" Property="Background" Value="#78909C" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>