{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "YourNamespace.ProductsController": "Debug" // 特定控制器更详细的日志
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./Logs/log-.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 10485760,
          "retainedFileCountLimit": 31,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "ModuleRunDataWebApi"
    }
  },
  //"Kestrel": {
  //  "Endpoints": {
  //    "Http": {
  //      "Url": "http://localhost:7166"
  //    }
  //  }
  //},
  "AllowedHosts": "*",
  "GlobalSets": {
    "DBSet": {
      "DbType": "mysql",
      "MySqlConnStr": "Server=localhost;Uid=root;Pwd=root;Database=sys;Persistsecurityinfo=false;Pooling=true;Min Pool Size=5;Max Pool Size=100;Connection Lifetime=300;",
      "SqlServerConnStr": "Server=123.56.45.66,1433;Database=master;User ID=sa;Password=SZTest123456;MultipleActiveResultSets=true;TrustServerCertificate=True;Pooling=true;Min Pool Size=5;Max Pool Size=100;Connection Lifetime=300;",
      "SqlLiteConnStr": "Data Source=d:/Module_databases/master.sqlite"
    },
    "NoSqlSet": {
      "RedisConfig": {
        "SingleConfig": "123.56.45.66:6380,password=Bqjx2024,defaultDatabase=0",
        "MasterSlaveConfigs": [
          "123.56.45.66:6380,password=Bqjx2024,defaultDatabase=0",
          "123.56.45.66:6381,password=Bqjx2024,defaultDatabase=0"
        ]
      },
